# Gemini API Key (Server-side fallback — user can also enter their own key via Settings)
VITE_GEMINI_API_KEY=

# Google OAuth Client ID (from GCP → APIs & Services → Credentials)
# Add your Vercel domain to "Authorized JavaScript origins" in the credential settings
VITE_GOOGLE_CLIENT_ID=

# Google Picker API Key (from GCP → APIs & Services → Credentials)
# Enable the "Google Picker API" and restrict this key to your domain
VITE_GOOGLE_PICKER_API_KEY=
